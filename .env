# Minecraft Client Loader Configuration
# Edit these values for your client

# URL to download the client archive (ZIP file)
CLIENT_DOWNLOAD_URL=https://example.com/client.zip

# Name of the JAR file inside the archive (relative path if in subfolder)
CLIENT_JAR_NAME=client.jar

# Default installation directory (used if user doesn't specify)
# Windows example: C:/MinecraftClient
# Linux example: /opt/minecraft-client
# macOS example: /Applications/MinecraftClient
DEFAULT_INSTALL_DIR=C:/MinecraftClient

# Client display name shown on the main page
CLIENT_DISPLAY_NAME=My Minecraft Client
